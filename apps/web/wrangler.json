{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "boat-search",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "boat-search-db",
      "database_id": "2489fb89-8ac3-435f-afff-c19bbf877509"
    }
  ],
  "routes": [
    {
      "pattern": "boat-search.nard.uk",
      "custom_domain": true
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "cb44ad7d6fa2450cb3698179c036c735",
      "preview_id": "cd997ffc21f9483b8c528591de1ff716"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "boat-search-images"
    }
  ]
}
