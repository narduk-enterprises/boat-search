{
  "name": "boat-search",
  "version": "1.17.2",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "predev": "node tools/check-setup.cjs",
    "dev": "pnpm --filter web dev",
    "prebuild": "node tools/check-setup.cjs",
    "build": "pnpm -r build",
    "preship": "node tools/check-setup.cjs && pnpm install --frozen-lockfile && pnpm audit --audit-level=critical && pnpm exec tsx tools/check-drift-ci.ts && pnpm exec tsx tools/check-sync-health.ts && pnpm run quality:check",
    "ship": "PLATFORM_SECRETS_ALLOW_FALLBACK=0 pnpm exec tsx tools/ship.ts",
    "ship:ci": "PLATFORM_SECRETS_ALLOW_FALLBACK=0 pnpm exec tsx tools/ship.ts --ci",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "pnpm run quality:fix && pnpm run quality:check",
    "quality:fix": "turbo run lint --force -- --fix && pnpm run format",
    "check": "pnpm run quality:check",
    "setup": "npx tsx tools/init.ts",
    "update-layer": "pnpm exec tsx tools/update-layer.ts",
    "sync-template": "pnpm exec tsx tools/sync-template.ts .",
    "validate": "pnpm exec tsx tools/validate.ts",
    "check:sync-health": "pnpm exec tsx tools/check-sync-health.ts",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install && pnpm --filter web run db:ready",
    "db:migrate": "pnpm --filter web run db:migrate",
    "crawler:setup": "pnpm --filter boat-crawler run setup:db",
    "crawler:texas": "pnpm --filter boat-crawler run crawl:texas",
    "crawler:yachtworld": "pnpm --filter boat-crawler run crawl:yachtworld",
    "crawler:scrape": "pnpm --filter boat-crawler run scrape:boats",
    "crawler:all": "bash packages/boat-crawler/scripts/crawl-all.sh",
    "crawler:ui": "pnpm --filter boat-crawler run ui",
    "seed:boats": "pnpm exec tsx tools/seed-boats.ts",
    "seed:boats:production": "pnpm exec tsx tools/seed-boats.ts --production",
    "seed:boats:refresh-sample": "pnpm exec tsx tools/refresh-representative-boat-seed.ts",
    "boats:geo:backfill": "pnpm exec tsx tools/backfill-boat-geo.ts",
    "boats:geo:backfill:production": "pnpm exec tsx tools/backfill-boat-geo.ts --production",
    "boats:dedupe:rebuild": "pnpm exec tsx tools/rebuild-boat-dedupe.ts",
    "boats:dedupe:rebuild:production": "pnpm exec tsx tools/rebuild-boat-dedupe.ts --production",
    "boats:inventory:validate": "pnpm exec tsx tools/validate-boat-inventory.ts",
    "boats:inventory:validate:production": "PLATFORM_SECRETS_ALLOW_FALLBACK=0 node ./tools/run-with-platform-secrets.mjs --app boat-search --environment prd --profile build -- pnpm exec tsx tools/validate-boat-inventory.ts --production",
    "extension:build": "pnpm --filter chrome-scraper-extension run build",
    "extension:lint": "pnpm --filter chrome-scraper-extension run lint",
    "extension:typecheck": "pnpm --filter chrome-scraper-extension run typecheck",
    "yachtworld:csv-sql": "pnpm --filter web run yachtworld:csv-sql",
    "dev:kill": "sh scripts/dev-kill.sh",
    "test:e2e": "playwright test",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "test:e2e:extension": "pnpm --filter chrome-scraper-extension run build && playwright test --config=packages/chrome-scraper-extension/playwright.live.config.ts",
    "generate:favicons": "pnpm exec tsx tools/generate-favicons.ts",
    "format": "prettier --write \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  New apps: provision via the control plane (see AGENTS.md). Generated starters get .setup-complete from provisioning.\\n')\"",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "hooks:install": "node tools/install-git-hooks.cjs",
    "guardrails:repo": "pnpm exec tsx tools/check-guardrails.ts",
    "cleanup:node-leaks": "sh scripts/cleanup-node-leaks.sh",
    "quality:check": "pnpm run guardrails:repo && turbo run quality --filter='./apps/*'",
    "sync:github-skills": "pnpm exec tsx tools/sync-github-skills.ts"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3",
      "@cloudflare/unenv-preset": "2.12.1",
      "nuxt-og-image": "6.1.2",
      "@takumi-rs/core": ">=0.70.1",
      "@takumi-rs/wasm": ">=0.70.1",
      "@cloudflare/workers-types": "4.20260307.1",
      "@typescript-eslint/utils": "^8.57.0",
      "@nuxt/eslint": "^1.15.2",
      "eslint-plugin-unicorn": "^63.0.0"
    },
    "peerDependencyRules": {
      "allowAny": [
        "eslint",
        "citty",
        "@cloudflare/workers-types"
      ]
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.13",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.2.1",
    "googleapis": "^171.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12"
  }
}
